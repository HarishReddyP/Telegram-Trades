# ---- Core ----
DATABASE_URL=postgresql+psycopg://trader:traderpass@db:5432/trades
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# ---- Trading safety gates ----
TRADING_MODE=paper            # paper | live
MANUAL_APPROVAL=true          # require human approval before any order
LIVE_TRADING_ENABLED=false    # hard gate; must be true AND mode=live for real orders
KILL_SWITCH=false             # true halts all new orders

# ---- Account / default risk ----
STARTING_CAPITAL=25000
MAX_RISK_PER_TRADE=500
MAX_CONTRACTS_PER_TRADE=5
MAX_DAILY_LOSS=1000
MAX_OPEN_TRADES=5
ALLOWED_TICKERS=SPX,SPY,QQQ,IWM
ALLOWED_STRATEGIES=BULL_PUT_SPREAD,BEAR_CALL_SPREAD,IRON_CONDOR,IRON_FLY,BUTTERFLY,SINGLE_LEG
NO_TRADE_NEAR_CLOSE=true
NO_TRADE_MINUTES_BEFORE_CLOSE=15
COMMISSION_PER_CONTRACT=0.65

# ---- Telegram ----
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL=@your_channel_handle

# ---- Email / SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
REPORT_RECIPIENT=you@example.com

# ---- Market session (US/Eastern assumed) ----
MARKET_TZ=America/New_York
MARKET_CLOSE=16:00

# ---- Live quotes (Tradier market data; read-only, no orders) ----
QUOTE_PROVIDER=none                 # none | tradier  (set to 'tradier' to enable live prices)
TRADIER_TOKEN=                      # bearer token from Tradier (sandbox or production)
TRADIER_BASE_URL=https://sandbox.tradier.com   # or https://api.tradier.com for production
FILL_PRICE_MODE=mid                 # mid | conservative  (how paper fills & marks are priced)
