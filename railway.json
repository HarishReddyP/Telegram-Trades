{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "bash -c 'cd backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "backend": {
      "build": {
        "context": "backend",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "bash -c 'cd backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
        "numReplicas": 1
      },
      "port": 8000
    },
    "worker": {
      "build": {
        "context": "backend",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "celery -A app.workers.celery_app worker -B --loglevel=info",
        "numReplicas": 1
      }
    },
    "telegram-listener": {
      "build": {
        "context": "backend",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "python -m app.services.telegram_listener",
        "numReplicas": 1
      }
    }
  },
  "plugins": {
    "postgres": {
      "version": "14"
    },
    "redis": {
      "version": "7"
    }
  }
}
