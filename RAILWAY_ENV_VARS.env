# Railway Environment Variables Template
# 
# Add these to your Railway project Variables (Project Settings → Variables)
# Sensitive ones (marked "Secret") should be encrypted.
# 
# Railway adds these automatically:
# - DATABASE_URL (from PostgreSQL add-on)
# - REDIS_URL (from Redis add-on)

# ---------- CORE CONFIG ----------
JWT_SECRET=your-random-32-char-secret-here
TRADING_MODE=paper
MANUAL_APPROVAL=true
LIVE_TRADING_ENABLED=false
KILL_SWITCH=false

# ---------- ACCOUNT / RISK CONFIG ----------
STARTING_CAPITAL=25000
MAX_RISK_PER_TRADE=500
MAX_CONTRACTS_PER_TRADE=5
MAX_DAILY_LOSS=1000
MAX_OPEN_TRADES=5
ALLOWED_TICKERS=SPX,SPY,QQQ,IWM
ALLOWED_STRATEGIES=BULL_PUT_SPREAD,BEAR_CALL_SPREAD,IRON_CONDOR,IRON_FLY,BUTTERFLY,SINGLE_LEG
NO_TRADE_NEAR_CLOSE=true
NO_TRADE_MINUTES_BEFORE_CLOSE=15
COMMISSION_PER_CONTRACT=0.65

# ---------- TELEGRAM (SECRETS) ----------
# Get API_ID and API_HASH from https://my.telegram.org
# TELEGRAM_SESSION is generated via: python -m app.services.telegram_session
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION=your_session_string_here
TELEGRAM_CHANNEL=@your_channel_or_numeric_id

# ---------- ANTHROPIC (OPTIONAL - for image parsing) ----------
ANTHROPIC_API_KEY=sk-ant-...

# ---------- EMAIL (OPTIONAL - for notifications) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@example.com
REPORT_RECIPIENT=recipient@example.com

# ---------- MARKET SESSION ----------
MARKET_TZ=America/New_York
MARKET_CLOSE=16:00

# ---------- QUOTES / TRADIER (OPTIONAL) ----------
QUOTE_PROVIDER=none
TRADIER_TOKEN=your-tradier-token
TRADIER_BASE_URL=https://sandbox.tradier.com
FILL_PRICE_MODE=mid
